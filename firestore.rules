rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Collection: Employees
    match /employees/{id} {
      allow read, write: if true;
    }

    // Collection: Payroll
    match /payroll/{id} {
      allow read, write: if true;
    }

    // Collection: Leaves
    match /leaves/{id} {
      allow read, write: if true;
    }

    // Collection: Sales
    match /sales/{id} {
      allow read, write: if true;
    }

    // Collection: Cheques
    match /cheques/{id} {
      allow read, write: if true;
    }

    // Collection: Cashflow
    match /cashflow/{id} {
      allow read, write: if true;
    }

    // Collection: Partner Billings
    match /partner_billings/{id} {
      allow read, write: if true;
    }

    // Collection: Audit Logs
    match /audit_logs/{id} {
      allow read, write: if true;
    }

    // Collection: Jobs
    match /jobs/{id} {
      allow read, write: if true;
    }

    // Collection: Applicants
    match /applicants/{id} {
      allow read, write: if true;
    }

    // Collection: Evaluations
    match /evaluations/{id} {
      allow read, write: if true;
    }

    // Collection: Attendance
    match /attendance/{id} {
      allow read, write: if true;
    }

    // Collection: Dayoff Swaps
    match /dayoff_swaps/{id} {
      allow read, write: if true;
    }

    // Collection: Partner Companies
    match /partner_companies/{id} {
      allow read, write: if true;
    }

    // Collection: System Settings
    match /system_settings/{id} {
      allow read, write: if true;
    }

    // Collection: Consolidated High-Performance Tables
    match /consolidated_tables/{id} {
      allow read, write: if true;
    }
  }
}
